# Version-agnostic build recipe for {{.Owner}}/{{.Repo}}.
#
# Written ONCE when the repo is onboarded; the generator never overwrites this
# file. It only stamps new versions into pkgs/{{.Repo}}/<major>_<minor>.nix,
# which call this with `version` + `rev` + `hash`.
#
# Replace the generic passthrough install below with the real build for
# {{.Repo}} (buildInputs, buildPhase, ...) and set the correct meta.license.
{ lib, stdenv, fetchFromGitHub, version, rev, hash }:

stdenv.mkDerivation {
  pname = "{{.Repo}}";
  inherit version;

  src = fetchFromGitHub {
    owner = "{{.Owner}}";
    repo = "{{.Repo}}";
    inherit rev hash;
  };

  # Generic passthrough: install the source tree as-is. Replace with the real
  # build once it is known for {{.Repo}}.
  dontBuild = true;
  installPhase = ''
    runHook preInstall
    mkdir -p "$out"
    cp -r . "$out"
    runHook postInstall
  '';

  meta = {
    description = "Auto-patched build of {{.Owner}}/{{.Repo}} (passthrough until a real recipe is added)";
    homepage = "https://github.com/{{.Owner}}/{{.Repo}}";
    # TODO(onboarding): set the real upstream license.
    license = lib.licenses.mit;
    platforms = lib.platforms.all;
  };
}
